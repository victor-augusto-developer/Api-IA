<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI Usage Dashboard</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />

  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div class="page" id="page">

    <header class="header">
      <div class="header__brand">
        <div class="header__logo" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L2 7L12 12L22 7L12 2Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
            <path d="M2 17L12 22L22 17" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
            <path d="M2 12L12 17L22 12" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="header__titles">
          <h1 class="header__title">AI Usage Dashboard</h1>
          <p class="header__subtitle">Monitoramento de consumo de tokens em tempo real</p>
        </div>
      </div>

      <div class="header__meta">
        <span class="badge">
          <span class="badge__dot"></span>
          Online
        </span>
      </div>
    </header>

    <main class="main">

      <section class="stats-grid" id="stats-grid">
        <div class="card stat-card">
          <span class="stat-card__label">Total de tokens</span>
          <span class="stat-card__value" id="stat-total">—</span>
          <span class="stat-card__hint" id="stat-total-hint">Últimos dias monitorados</span>
        </div>

        <div class="card stat-card">
          <span class="stat-card__label">Média diária</span>
          <span class="stat-card__value" id="stat-average">—</span>
          <span class="stat-card__hint">Tokens por dia</span>
        </div>

        <div class="card stat-card">
          <span class="stat-card__label">Pico de uso</span>
          <span class="stat-card__value" id="stat-peak">—</span>
          <span class="stat-card__hint" id="stat-peak-hint">Maior consumo registrado</span>
        </div>

        
      </section>

      <section class="card chart-card">
        <div class="chart-card__header">
          <div>
            <h2 class="chart-card__title">Consumo de tokens</h2>
            <p class="chart-card__subtitle">Volume diário de tokens processados pela IA</p>
            <span class="chart-card__live">
              <span class="chart-card__live-dot"></span>
              Atualização automática
            </span>
          </div>

          <div class="chart-card__stat">
            <span class="chart-card__stat-value" id="chart-latest-value">—</span>
            <span class="chart-card__stat-trend" id="chart-trend">
              <svg class="chart-card__stat-trend-icon" width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M2 8L6 4L10 8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span id="chart-trend-value">0%</span>
            </span>
          </div>
        </div>

        <div class="chart-card__canvas-wrapper">
          <canvas id="usageChart"></canvas>
        </div>
      </section>

      <section class="card danger-card">
        <div class="danger-card__info">
          <h2 class="danger-card__title">Zona de perigo</h2>
          <p class="danger-card__subtitle">Apaga permanentemente todos os dados armazenados no banco de dados. Essa ação não pode ser desfeita.</p>
        </div>
        <button type="button" class="btn btn--danger" id="delete-database-btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M3 6H21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            <path d="M8 6V4C8 3.44772 8.44772 3 9 3H15C15.5523 3 16 3.44772 16 4V6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M19 6L18.2987 19.2687C18.2645 19.9245 17.7222 20.4444 17.0655 20.4444H6.93453C6.27779 20.4444 5.73551 19.9245 5.70125 19.2687L5 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Delete Database
        </button>
      </section>

    </main>

    <footer class="footer">
      <p>
        AI Usage Dashboard &mdash; painel interno de monitoramento
        <span class="footer__dot">&middot;</span>
        <span id="last-updated">atualizado agora</span>
      </p>
    </footer>

  </div>

  <div class="modal-overlay" id="delete-modal-overlay" hidden>
    <div class="modal" role="alertdialog" aria-modal="true" aria-labelledby="delete-modal-title" aria-describedby="delete-modal-desc">
      <div class="modal__icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 9V13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          <path d="M12 16.5V16.51" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          <path d="M10.29 3.86L1.82 18A1.5 1.5 0 003.11 20.25H20.89A1.5 1.5 0 0022.18 18L13.71 3.86A1.5 1.5 0 0010.29 3.86Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
        </svg>
      </div>

      <h2 class="modal__title" id="delete-modal-title">Apagar banco de dados</h2>
      <p class="modal__desc" id="delete-modal-desc">
        Esta ação vai apagar permanentemente todos os dados de consumo armazenados. Isso não pode ser desfeito.
      </p>

      <label class="modal__confirm-label" for="delete-modal-input">
        Digite <strong>DELETE</strong> para confirmar
      </label>
      <input
        type="text"
        class="modal__input"
        id="delete-modal-input"
        autocomplete="off"
        spellcheck="false"
        placeholder="DELETE"
      />

      <div class="modal__actions">
        <button type="button" class="btn btn--ghost" id="delete-modal-cancel">Cancelar</button>
        <button type="button" class="btn btn--danger" id="delete-modal-confirm" disabled>Apagar banco de dados</button>
      </div>
    </div>
  </div>

  <script>
    const usage = <%- JSON.stringify(usage) %>;
  </script>

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>

  <script src="/js/script.js"></script>
</body>
</html>
